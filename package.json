{
  "name": "trade-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "A macOS Chromium-based stock research assistant with React, Electron, and Python APIs.",
  "main": "electron/main.cjs",
  "scripts": {
    "setup:py": "python3 -m venv .venv && .venv/bin/python -m pip install --upgrade pip && .venv/bin/pip install -r backend/requirements.txt",
    "dev:api": ".venv/bin/uvicorn backend.app.main:app --host 127.0.0.1 --port 8765 --reload",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:5173 tcp:8765 && electron .",
    "dev": "concurrently -k -n api,ui,electron -c cyan,magenta,green \"npm:dev:api\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build": "tsc && vite build",
    "start": "electron .",
    "package:mac": "npm run build && electron-builder --mac",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "lucide-react": "^0.468.0",
    "vite": "^5.0.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "concurrently": "^8.2.2",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tradeassistant.desktop",
    "productName": "Trade Assistant",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance"
    }
  }
}
